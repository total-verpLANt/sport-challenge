# REQUIRED: App startet nicht ohne diesen Key (mind. 32 zufällige Zeichen in Produktion)
SECRET_KEY=aendere-mich-in-produktion

# Strava OAuth (optional – ohne diese Var verschwindet Strava aus der UI)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Docker / Deployment
# Upload-Verzeichnis (Standard: app/static/uploads relativ zum Projektroot)
# In Docker: UPLOAD_FOLDER=/app/app/static/uploads (oder per Volume-Mount leer lassen)
UPLOAD_FOLDER=

# WSGI-Server: Anzahl Gunicorn-Worker
# ACHTUNG: Wert > 1 macht Rate-Limits pro Worker statt global (In-Memory-Limiter)!
GUNICORN_WORKERS=1

# Flask CLI (für flask db upgrade im Container-Entrypoint)
FLASK_APP=run.py
